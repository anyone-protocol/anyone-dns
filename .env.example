# anyone-dns local env example
# Copy to `.env` and adjust as needed.

# HTTP port the service listens on
PORT=3000

# Optional healthcheck metadata
VERSION=local
HIDDEN_SERVICE_HOSTNAME=
HIDDEN_SERVICE_PUBLIC_KEY=

# Optional: base64 of the 96-byte Tor `hs_ed25519_secret_key` file. When set,
# `/tld/anyone` returns a signed document per the anyone-hosts format spec.
# When unset, the endpoint returns the legacy unsigned `<domain> <hsaddr>`
# body. The derived signer address must match HIDDEN_SERVICE_HOSTNAME if that
# is also set.
HIDDEN_SERVICE_SECRET_KEY=

# Cache refresh interval (ms) for the in-memory hosts-list cache.
ANYONE_DOMAINS_CACHE_TTL_MS=300000

# Optional overlay file of `<domain> <hsaddr>` per line. Merged on top of DB.
# Uncomment and point at a real file if you want local overrides.
# DEFAULT_MAPPINGS_PATH=./default-anyone-hosts

# Postgres connection (schema is owned by the uns-record-indexer service).
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=uns_indexer
